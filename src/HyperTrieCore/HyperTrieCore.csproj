<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        
        <!-- NuGet Package Configuration -->
        <PackageId>HyperTrieCore</PackageId>
        <Version>1.0.0</Version>
        <Authors>Greg James</Authors>
        <Description>A high-performance trie implementation with native Rust backend.</Description>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageLicenseFile>LICENSE.md</PackageLicenseFile>
        <PackageTags>c-sharp trie prefixtrie performance rust native</PackageTags>
        <!-- Runtime Identifiers -->
        <RuntimeIdentifiers>win-x64;win-x86;linux-x64;osx-arm64</RuntimeIdentifiers>
        <PackageIcon>trie.png</PackageIcon>
        <Title>HyperTrieCore</Title>
        <Copyright>Greg James @ 2025</Copyright>
        <PackageProjectUrl>https://github.com/gregyjames/HyperTrie</PackageProjectUrl>
        <RepositoryUrl>https://github.com/gregyjames/HyperTrie</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
    </PropertyGroup>

    <!-- Native libraries for all platforms -->
    <ItemGroup>
        <None Include="..\..\trie.png" Pack="True" PackagePath="" Link="trie.png" />
        
        <!-- Native libraries from the build output (Packed for NuGet) -->
        <None Include="..\..\artifacts\native\windows-x64\hypertrie.dll" Pack="true" PackagePath="runtimes\win-x64\native" Condition="Exists('..\..\artifacts\native\windows-x64\hypertrie.dll')" />
        <None Include="..\..\artifacts\native\windows-x86\hypertrie.dll" Pack="true" PackagePath="runtimes\win-x86\native" Condition="Exists('..\..\artifacts\native\windows-x86\hypertrie.dll')" />
        <None Include="..\..\artifacts\native\linux-x64\libhypertrie.so" Pack="true" PackagePath="runtimes\linux-x64\native" Condition="Exists('..\..\artifacts\native\linux-x64\libhypertrie.so')" />
        <None Include="..\..\artifacts\native\osx-arm64\libhypertrie.dylib" Pack="true" PackagePath="runtimes\osx-arm64\native" Condition="Exists('..\..\artifacts\native\osx-arm64\libhypertrie.dylib')" />

        <!-- Native libraries for local development (Project References) -->
        <Content Include="..\..\artifacts\native\windows-x64\hypertrie.dll" Link="runtimes\win-x64\native\hypertrie.dll" CopyToOutputDirectory="PreserveNewest" Condition="Exists('..\..\artifacts\native\windows-x64\hypertrie.dll')" Pack="false" />
        <Content Include="..\..\artifacts\native\windows-x86\hypertrie.dll" Link="runtimes\win-x86\native\hypertrie.dll" CopyToOutputDirectory="PreserveNewest" Condition="Exists('..\..\artifacts\native\windows-x86\hypertrie.dll')" Pack="false" />
        <Content Include="..\..\artifacts\native\linux-x64\libhypertrie.so" Link="runtimes\linux-x64\native\libhypertrie.so" CopyToOutputDirectory="PreserveNewest" Condition="Exists('..\..\artifacts\native\linux-x64\libhypertrie.so')" Pack="false" />
        <Content Include="..\..\artifacts\native\osx-arm64\libhypertrie.dylib" Link="runtimes\osx-arm64\native\libhypertrie.dylib" CopyToOutputDirectory="PreserveNewest" Condition="Exists('..\..\artifacts\native\osx-arm64\libhypertrie.dylib')" Pack="false" />

        <None Include="build\HyperTrieCore.targets" Pack="true" PackagePath="build\HyperTrieCore.targets"/>
        <None Include="..\..\README.md" Pack="true" PackagePath="/" />
        <None Include="..\..\LICENSE.md" Pack="true" PackagePath="/" />
    </ItemGroup>

</Project>
